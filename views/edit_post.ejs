<%- include("partials/header"); -%>

    <main>
        <div class="container" style="margin-top: 1rem;">
            <div class="col-sm-6 col-sm-offset-3">
             <h2>Add a new post</h2>
          
             <form action="/edit_post/<%= post.post_id %>" method="post" enctype="multipart/form-data">
              <div class="form-group">
                  <label for="title">Title</label>
                  <input type="text" class="form-control" name="title" value="<%= post.title %>" required>
              </div>
              <div class="form-group">
                <label for="image">Thumbnail image</label><br>
                <input type="file" accept="image/*" name="image">
              </div>
              <div class="form-group">
               <label>Image title</label>
               <input type="text" class="form-control" name="img_alt" value="<%= post.img_alt %>">
              </div>
              <div class="form-group">
                <label for="content">Content</label>
                <textarea class="form-control" rows="10" name="content" required><%= post.content %></textarea>
              </div>
          
              <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Submit</button>
             </form>
          
             <hr>
          
             <p>Go Back <a href="/">Home</a>.</p>
            </div>
        </div>

        <div id="add_post">
            <form action="/edit_post/<%= post.post_id %>" method="post" enctype="multipart/form-data">
                <div id="title-block">
                    <label for="title">Title</label><br>
                    <input type="text" name="title" value="<%= post.title %>" required>
                    <br>
                </div>

                <div id="img_url-block">
                    <label for="image">Thumbnail image</label><br>
                    <input type="file" accept="image/*" name="image">
                    <br>
                </div>

                <div id="img_alt-block">
                    <label for="img_alt">Image alt</label><br>
                    <input type="text" name="img_alt" value="<%= post.img_alt %>">
                    <br>
                </div>

                <div id="content-block">
                    <label for="content">Content</label><br>
                    <textarea name="content" cols="30" rows="10" required><%= post.content %></textarea>
                    <br>
                </div>

                <input type="submit" value="Publish">
            </form>
        </div>
    </main>
    
 <!-- </div> -->
 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha2/dist/js/bootstrap.bundle.min.js" integrity="sha384-qKXV1j0HvMUeCBQ+QVp7JcfGl760yU08IQ+GpUo5hlbpg51QRiuqHAJz8+BrxE/N" crossorigin="anonymous"></script>
  </body>
</body>
</html>